import Flask, render_template, request
import requests

app = Flask(__name__)

@app.route('/')
def inicio():
    return "<h1>Panel Admin Roblox - Activo</h1><p>Escribe el ID del usuario en la URL para probar.</p>"

@app.route('/user/<int:user_id>')
def get_user(user_id):
    # Consultamos la API oficial de Roblox
    url = f"https://users.roblox.com/v1/users/{user_id}"
    response = requests.get(url)
    
    if response.status_code == 200:
        data = response.json()
        return f"""
        <html>
            <body style="font-family: sans-serif; background: #222; color: white;">
                <h2>Info del Usuario</h2>
                <p><b>Username:</b> {data.get('name')}</p>
                <p><b>DisplayName:</b> {data.get('displayName')}</p>
                <p><b>Descripción:</b> {data.get('description')}</p>
                <hr>
                <button onclick="alert('Acción de admin ejecutada')">Banear (Simulación)</button>
            </body>
        </html>
        """
    return "Usuario no encontrado", 404

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=8080)
